# ==============================================================================
# .env.example — Djesaja LiveBackstage AI Hub
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your actual .env file to version control.
# ==============================================================================


# ==============================================================================
# Django Core
# ==============================================================================

# Required. Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production
# Required | Default: False
DEBUG=True

# Comma-separated list of allowed hosts
# Required | Example: yourdomain.com,www.yourdomain.com
# For local Docker: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1


# ==============================================================================
# Database
# ==============================================================================

# Use 'django.db.backends.sqlite3' for development (no extra vars needed)
# Use 'django.db.backends.postgresql' for production
# Required | Default: django.db.backends.sqlite3
DB_ENGINE=django.db.backends.sqlite3

# Required only when DB_ENGINE is NOT sqlite3
DB_NAME=livebackstage_db
DB_USER=livebackstage_user
DB_PASSWORD=your_db_password_here
DB_HOST=db
DB_PORT=5432


# ==============================================================================
# Email (SMTP)
# ==============================================================================

# Required | Options:
#   django.core.mail.backends.console.EmailBackend  (local dev – prints to stdout)
#   django.core.mail.backends.smtp.EmailBackend     (production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP server hostname
# Required | Example: smtp.gmail.com
EMAIL_HOST=smtp.gmail.com

# SMTP port
# Required | Default: 587
EMAIL_PORT=587

# Enable TLS
# Required | Default: True
EMAIL_USE_TLS=True

# Your SMTP email address
# Required | Example: yourapp@gmail.com
EMAIL_HOST_USER=yourapp@gmail.com

# SMTP app password (NOT your login password - use Gmail App Passwords)
# Required
EMAIL_HOST_PASSWORD=your_email_app_password_here


# ==============================================================================
# CORS
# ==============================================================================

# Set to True to allow all origins (OK for dev, DISABLE in production)
# Default: True
CORS_ALLOW_ALL_ORIGINS=True

# Comma-separated list of allowed origins (used when CORS_ALLOW_ALL_ORIGINS=False)
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=


# ==============================================================================
# AI Service
# ==============================================================================

# Base URL of the external AI microservice that performs daily/monthly analysis
# Required | Example: http://your-ai-server-ip:8026
AI_SERVICE_BASE_URL=http://172.252.13.97:8026


# ==============================================================================
# Gunicorn (Docker Production)
# ==============================================================================

# Number of Gunicorn worker processes
# Recommended: (2 × CPU cores) + 1
# Default: 3
GUNICORN_WORKERS=3

# Request timeout in seconds
# Default: 120  (longer because Playwright scraping can take time)
GUNICORN_TIMEOUT=120

# Application port inside container
# Default: 8000
PORT=8000
